{
  "name": "angular-slider-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve angular-slider --open",
    "db": "json-server --watch db.json --port 3000",
    "dev": "concurrently -k -n db,ng -c magenta,cyan \"npm run db\" \"npm run start\"",
    "build": "ng build angular-slider",
    "build:lib": "ng build media-slider",
    "build:element": "ng build media-slider-element",
    "build:all": "npm run build:lib && npm run build:element && npm run build",
    "serve:element": "ng serve media-slider-element --open",
    "pack:lib": "npm run build:lib && cd dist/media-slider && npm pack && cd ../.. && mv dist/media-slider/*.tgz dist/",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/elements": "^19.2.21",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "concurrently": "^9.2.1",
    "json-server": "^0.17.4",
    "ng-packagr": "^19.2.2",
    "typescript": "~5.6.0"
  }
}
