{
  "name": "angular-slider-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve angular-slider --open",
    "build": "ng build angular-slider",
    "build:lib": "ng build tiktok-slider",
    "build:element": "ng build tiktok-slider-element",
    "build:all": "npm run build:lib && npm run build:element && npm run build",
    "serve:element": "ng serve tiktok-slider-element --open",
    "pack:lib": "npm run build:lib && cd dist/tiktok-slider && npm pack && cd ../.. && mv dist/tiktok-slider/*.tgz dist/",
    "watch": "ng build --watch --configuration development"
  },
  "dependencies": {
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/elements": "^19.2.21",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "ng-packagr": "^19.2.2",
    "typescript": "~5.6.0"
  }
}
